# wshowlyrics configuration file
#
# Configuration file locations (in priority order):
#   1. ~/.config/wshowlyrics/settings.ini (user configuration)
#   2. /etc/wshowlyrics/settings.ini (system-wide configuration)
#
# All settings are optional - if not specified, defaults will be used
# You can also override settings using command-line arguments

[display]
# Font settings
# font_family: Font family name (default: Sans)
# font_size: Font size in points (default: 20)
# font_weight: Font weight - normal, bold, etc. (default: normal)
font_family = Sans
font_size = 20
font_weight = normal

# Colors in RRGGBBAA hex format (Red Green Blue Alpha)
# Each color component is 00-FF (0-255)
# Examples:
#   FFFFFFFF = White, fully opaque
#   000000CC = Black, semi-transparent (80% opacity)
#   FF0000FF = Red, fully opaque
#   00FF00FF = Green, fully opaque
#   0000FFFF = Blue, fully opaque
#   808080FF = Gray, fully opaque

# Active text color (highlighted/current lyrics)
# Note: Pending/waiting text is automatically displayed as 50% dimmed version of this color
color_active = FFFFFFFF

# Background color
color_background = 00000080

# Position and spacing
# anchor: Anchor position - top, bottom, left, right (default: bottom)
# margin: Distance from edge of screen in pixels (default: 32)
# line_spacing: Space between lines in pixels (default: 10)
anchor = bottom
margin = 32
line_spacing = 10

# Multi-line display for LRCX format
# When enabled, LRCX files display 3 lines: previous, current (with karaoke), and next
# Previous line: 70% scale, no ruby text, 75% opacity
# Current line: Full scale, ruby text + karaoke timing effect
# Next line: 70% scale, no ruby text, 50% opacity
# This only affects LRCX format - LRC/SRT remain single-line
# Set to false to show only the current line (default: true)
enable_multiline_lrcx = true

[lyrics]
# Search directories (colon-separated paths)
# Empty string or not set = use default search locations
# Default locations:
#   1. Same directory as the music file
#   2. Current directory (only for local builds, not /usr/bin)
#   3. XDG_MUSIC_DIR environment variable
#   4. ~/.lyrics/
#   5. $HOME
#
# Example: search_dirs = ~/.lyrics:~/Music:~/Documents/Lyrics
search_dirs =

# File extensions to search (comma-separated, no dots)
# Supported formats: lrcx, lrc, srt, vtt
# If empty or not set, all formats are searched
# Example: extensions = lrc,srt (this would skip .lrcx and .vtt files)
extensions = lrcx,lrc,srt,vtt

# Preferred music players (comma-separated player names)
# Empty string or not set = use %any (all players except browsers)
# This setting allows you to prioritize specific music players
# Common player names: mpv, spotify, vlc, rhythmbox, audacious
# Example: preferred_players = mpv,spotify
# Note: Browsers (chromium, firefox) are always ignored regardless of this setting
preferred_players =

# Online lyrics provider (lrclib.net)
# Set to false to disable online lyrics fetching
# Only used when local files are not found
enable_lrclib = true

# Album artwork provider (iTunes Search API)
# Set to false to disable iTunes API artwork fetching
# Only used when MPRIS doesn't provide album art
# Works best when lrclib provides accurate artist/track metadata
enable_itunes = true

# Desktop notifications for track changes
# Set to false to disable desktop notifications when the track changes
# Uses notify-send to display artist, track, and album art
enable_notifications = true

# Notification timeout in milliseconds (default: 5000)
# How long the notification stays visible before auto-dismissing
# Examples: 3000 (3 seconds), 5000 (5 seconds), 7000 (7 seconds)
notification_timeout = 5000

[deepl]
# DeepL API translation settings
# Automatic translation of LRC lyrics files (does not apply to SRT, VTT, or LRCX)
# Note: This feature requires a DeepL API key (Free or Pro)

# Enable DeepL translation feature
# Set to true to enable automatic translation of LRC lyrics
# Set to false to disable translation (show only original lyrics)
enable_deepl = false

# DeepL API key
# Get your API key at: https://www.deepl.com/pro-api
# Free API keys end with :fx (e.g., "abc123-def456:fx")
# Pro API keys do not have this suffix
# The correct API endpoint is automatically selected based on the key format
api_key =

# Target language for translation
# Supported language codes:
#   BG (Bulgarian), CS (Czech), DA (Danish), DE (German), EL (Greek)
#   EN (English), ES (Spanish), ET (Estonian), FI (Finnish), FR (French)
#   HU (Hungarian), ID (Indonesian), IT (Italian), JA (Japanese), KO (Korean)
#   LT (Lithuanian), LV (Latvian), NL (Dutch), PL (Polish), PT (Portuguese)
#   RO (Romanian), RU (Russian), SK (Slovak), SL (Slovenian), SV (Swedish)
#   TR (Turkish), UK (Ukrainian), ZH (Chinese)
# Default: EN (English)
target_language = EN

# Translation display mode
# Options:
#   both - Show both original and translation (translation displayed below original in smaller text)
#   translation_only - Show only translated lyrics (hide original)
# Default: both
translation_display = both

# Translation text opacity (0.0 - 1.0)
# Controls how transparent/visible the translation text appears
# Lower values make the translation more transparent (harder to see)
# Higher values make the translation more opaque (easier to see)
# Examples:
#   0.5 = 50% opacity (very transparent)
#   0.7 = 70% opacity (default, slightly transparent)
#   0.9 = 90% opacity (almost fully opaque)
#   1.0 = 100% opacity (fully opaque, same as original text)
# Default: 0.7
translation_opacity = 0.7

[behavior]
# Reserved for future behavior settings
# This section is currently not used but may be expanded in future releases
